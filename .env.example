# Jira Configuration
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@domain.com
JIRA_API_TOKEN=your-api-token

# Optional - Project filter (default: SUP)
# JIRA_PROJECT=SUP

# Optional - Status filter (leave empty for all statuses)
# Examples: Done, In Progress, To Do
# JIRA_STATUS_FILTER=

# App Configuration
SECRET_KEY=change-this-to-something-random
